# =============================================================================
# 教師密碼登入（必填）
# =============================================================================
TEACHER_PASSWORD=請改成強密碼

# =============================================================================
# JWT 簽名密鑰（必填，openssl rand -hex 32）
# =============================================================================
JWT_SECRET=請改成隨機字串

# =============================================================================
# 資料庫連線字串（必填）— Neon PostgreSQL
# =============================================================================
DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# =============================================================================
# 圖片儲存（四選一）
# =============================================================================

# --- 選項 A：Backblaze B2（推薦，10GB 永久免費、**不需信用卡**）---
# 申請：https://www.backblaze.com/b2 → Sign Up（email 即可）→ Create Bucket
# App Keys → Create → 權限: Read & Write，綁定 bucket
# Bucket Settings → 開 Lifecycle: 不要刪檔案
# 開啟 Public Access（Bucket Detail → 複製 Friendly URL）
S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004
S3_ACCESS_KEY_ID=你的_key_ID
S3_SECRET_ACCESS_KEY=你的_secret_key
S3_BUCKET=quiz-platform-uploads
S3_PUBLIC_BASE=https://f004.backblazeb2.com/file/quiz-platform-uploads

# --- 選項 B：Cloudflare R2（10GB 永久免費，但**需要信用卡**驗證）---
# S3_ENDPOINT=https://你的account_id.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_BUCKET=quiz-platform-uploads
# S3_PUBLIC_BASE=https://pub-xxxxx.r2.dev

# --- 選項 C：Manus Forge（Manus 平台專用）---
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=your_key

# --- 選項 D：本地磁碟（要主機有 persistent disk）---
# LOCAL_STORAGE_DIR=/opt/render/project/src/uploads

# =============================================================================
# 環境
# =============================================================================
NODE_ENV=production
PORT=3000