# =============================================================================
# 教師密碼登入（必填）
# 設定後才能登入教師後台。留空則拒絕所有登入，避免不小心對外開放。
# =============================================================================
TEACHER_PASSWORD=請改成強密碼

# =============================================================================
# JWT 簽名密鑰（必填）
# 用來簽 HttpOnly cookie，建議用 openssl rand -hex 32 產生
# =============================================================================
JWT_SECRET=請改成隨機字串_例如_openssl_rand_hex_32

# =============================================================================
# 資料庫連線字串（必填）— Neon PostgreSQL
#
# 1. 註冊 https://neon.tech（用 GitHub 一鍵）
# 2. 建立 project → 拿到 connection string
# 3. 格式：postgresql://username:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
#
# Neon 永久免費 0.5GB。
# 本地開發可以用 Docker：
#   docker run --name pg -e POSTGRES_PASSWORD=dev -p 5432:5432 -d postgres:16
#   DATABASE_URL=postgresql://postgres:dev@localhost:5432/postgres
# =============================================================================
DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# =============================================================================
# 圖片儲存模式（二選一）
# =============================================================================

# 模式 A：Manus Forge（Manus 平台專用，外部部署用不到）
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=你的forge_key

# 模式 B：本地檔案系統（自架、Render、Fly.io、VPS 都用這個）
# 留空則 fallback 到本地模式。Render 會把 disk mount 到這個路徑。
LOCAL_STORAGE_DIR=/opt/render/project/src/uploads

# =============================================================================
# 環境
# =============================================================================
NODE_ENV=production
PORT=3000