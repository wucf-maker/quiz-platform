# =============================================================================
# 教師密碼登入（必填）
# 設定後才能登入教師後台。留空則拒絕所有登入，避免不小心對外開放。
# =============================================================================
TEACHER_PASSWORD=請改成強密碼

# =============================================================================
# JWT 簽名密鑰（必填）
# 用來簽 HttpOnly cookie，建議用 openssl rand -hex 32 產生
# =============================================================================
JWT_SECRET=請改成隨機字串_例如_openssl_rand_hex_32

# =============================================================================
# MySQL 資料庫連線字串（必填）
# 本地範例：mysql://root:密碼@localhost:3306/quiz_platform
# 推薦外部服務：PlanetScale / Aiven / TiDB Cloud（都有免費方案）
# =============================================================================
DATABASE_URL=mysql://user:password@host:3306/dbname

# =============================================================================
# 圖片儲存模式（二選一）
# =============================================================================

# 模式 A：Manus Forge（Manus 平台專用，外部部署用不到）
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=你的forge_key

# 模式 B：本地檔案系統（自架、Render、Fly.io、VPS 都用這個）
# 留空則 fallback 到本地模式。目錄不存在會自動建立。
LOCAL_STORAGE_DIR=./uploads

# =============================================================================
# 環境
# =============================================================================
NODE_ENV=production
PORT=3000

# Vite 注入的前端 env（通常不用改）
# VITE_APP_ID=
# VITE_OAUTH_PORTAL_URL=