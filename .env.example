# =============================================================================
# 教師密碼登入（必填）
# =============================================================================
TEACHER_PASSWORD=請改成強密碼

# =============================================================================
# JWT 簽名密鑰（必填，用 openssl rand -hex 32 產生）
# =============================================================================
JWT_SECRET=請改成隨機字串

# =============================================================================
# 資料庫連線字串（必填）— Neon PostgreSQL
# 免費 0.5GB，https://neon.tech
# =============================================================================
DATABASE_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# =============================================================================
# 圖片儲存（三選一）
# =============================================================================

# --- 選項 A：Cloudflare R2（推薦，永久免費 10GB）---
# 申請：https://dash.cloudflare.com → R2 → Create bucket → Manage R2 API Tokens
# 設 R2_PUBLIC_BASE 可以用自訂 CDN domain，否則用預設 r2.dev URL
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=quiz-platform-uploads
# R2_PUBLIC_BASE=https://pub-xxxxx.r2.dev  ← 選填，自訂 CDN

# --- 選項 B：Manus Forge（Manus 平台專用）---
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=your_key

# --- 選項 C：本地磁碟（要主機有 persistent disk：Render disk / VPS）---
# LOCAL_STORAGE_DIR=/opt/render/project/src/uploads

# =============================================================================
# 環境
# =============================================================================
NODE_ENV=production
PORT=3000